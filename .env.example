# OpenCure Labs — Environment Variables
# Copy this file: cp .env.example .env
# Then fill in your API keys. Never commit .env to git.

# ── Required ─────────────────────────────────────────────────────────────────

# Gemini API key — coordinator LLM (Gemini 2.0 Flash Lite)
# Get one at: https://aistudio.google.com/apikey
GENAI_API_KEY=

# xAI API key — Grok researcher and literature monitor
# Get one at: https://console.x.ai/
XAI_API_KEY=

# ── Optional ─────────────────────────────────────────────────────────────────

# NVIDIA API key — only needed if using hosted NIM endpoints
# Get one at: https://build.nvidia.com/
NVIDIA_API_KEY=

# PostgreSQL connection string (default works for local dev)
POSTGRES_URL=postgresql://localhost:5433/opencurelabs

# Vast.ai API key — burst GPU compute for heavy pipelines
# Get one at: https://cloud.vast.ai/account/
VAST_AI_KEY=

# Vast.ai spending cap in USD — dispatcher refuses new instances when exceeded
# Set to 0 or remove for unlimited (not recommended)
VAST_AI_BUDGET=100
