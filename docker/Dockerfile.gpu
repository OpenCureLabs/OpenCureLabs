# ── LabClaw GPU Image ────────────────────────────────────────────────────────
# All bioinformatics tools and Python packages pre-installed for Vast.ai batch
# compute. Instances only need the agentiq_labclaw wheel installed at boot.
#
# Build:
#   docker build -f docker/Dockerfile.gpu -t ghcr.io/opencurelabs/labclaw-gpu:latest .
#
# Size estimate: ~11 GB (pytorch base ≈6 GB + biotools ≈4 GB + vet genomes ≈1 GB)
# ─────────────────────────────────────────────────────────────────────────────

FROM pytorch/pytorch:latest

LABEL org.opencontainers.image.source="https://github.com/OpenCureLabs/OpenCureLabs"
LABEL org.opencontainers.image.description="LabClaw GPU compute image for OpenCure Labs batch pipelines"

# Avoid interactive prompts during apt install
ENV DEBIAN_FRONTEND=noninteractive

# ── System packages ──────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    openbabel \
    fastp \
    autodock-vina \
    wget \
    curl \
    openssh-client \
    git \
    && rm -rf /var/lib/apt/lists/*

# ── Python packages ─────────────────────────────────────────────────────────
RUN pip install --no-cache-dir \
    rdkit-pypi \
    pydantic>=2.0 \
    psycopg2-binary>=2.9 \
    requests>=2.28 \
    mhcflurry>=2.1 \
    pysam>=0.22 \
    pyensembl>=2.3 \
    biopython>=1.83 \
    reportlab>=4.1 \
    openai>=1.20 \
    joblib>=1.3 \
    numpy \
    pandas \
    scikit-learn \
    tensorflow[and-cuda]>=2.16

# ── Pre-fetch model data (baked into image, avoids 10+ min first-run) ───────
# MHCflurry pan-allele binding prediction models (~200 MB)
RUN mhcflurry-downloads fetch models_class1_pan

# PyEnsembl genome annotations — baked in to avoid cold-download on Vast.ai
# Human GRCh38 release 110 (~500 MB) — used by all human pipelines
RUN pyensembl install --release 110 --species human
# Canine CanFam3.1 release 111 (~400 MB) — used by dog neoantigen/variant pipelines
RUN pyensembl install --release 111 --species dog
# Feline Felis_catus_9.0 release 111 (~350 MB) — used by cat neoantigen/variant pipelines
RUN pyensembl install --release 111 --species cat

# ── Marker for dependency availability ──────────────────────────────────────
RUN touch /tmp/labclaw_deps_ready

# ── Verify all tools are available ──────────────────────────────────────────
RUN python3 -c "import rdkit, mhcflurry, pysam, pyensembl, Bio, reportlab, sklearn, joblib" \
    && which vina obabel fastp

WORKDIR /workspace
