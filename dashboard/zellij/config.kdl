// ──────────────────────────────────────────────────────────────────────────────
//  OpenCure Labs — Zellij Configuration
//  Loaded by dashboard/lab.sh when launching the lab session.
// ──────────────────────────────────────────────────────────────────────────────

theme "tokyonight"

// Mouse support — click panes, scroll output, resize borders
mouse_mode true

// Show pane frames with names
pane_frames true

// Scrollback depth
scroll_buffer_size 50000

// Don't attach to existing sessions on launch — lab.sh handles this
on_force_close "quit"

// Default shell
default_shell "bash"

// Default layout — loads layouts/opencurelabs.kdl
default_layout "opencurelabs"

// Disable session serialization prompts
session_serialization false

// Copy behaviour
copy_on_select true

// Keybindings
//
//  Alt+1/2/3  — jump to Lab / Agents / Monitor tab
//  Alt+n      — next tab       Alt+p  — previous tab
//  Alt+←/→    — move focus left/right between panes
//  Alt+↑/↓    — move focus up/down between panes
//  Alt+q      — clean shutdown (auto-commit, push, kill session)
//  Alt+f      — findings popup
//  Alt+s      — start research task (interactive menu in floating pane)
//  Alt+c      — stop running agents without quitting
//  Alt+w      — close the focused pane
//  Alt+x      — toggle floating panes (hide/show)
//  Ctrl+p n   — new pane (if you actually need one)
//
keybinds {
    shared_except "locked" {
        // ── Tab switching ────────────────────────────────────────────────
        // Alt+n — next tab (overrides default NewPane)
        bind "Alt n" { GoToNextTab; }
        // Alt+p — previous tab
        bind "Alt p" { GoToPreviousTab; }
        // Alt+1/2/3 — jump directly to tab
        bind "Alt 1" { GoToTab 1; }
        bind "Alt 2" { GoToTab 2; }
        bind "Alt 3" { GoToTab 3; }

        // ── OpenCure Labs commands ───────────────────────────────────────
        // Alt+q — stop dashboard and quit Zellij
        bind "Alt q" {
            Run "bash" "-c" "bash $PROJECT_DIR/dashboard/stop.sh --pre-quit" {
                close_on_exit true
            }
            Quit;
        }
        // Alt+f — detailed findings: novel results + critique scores
        bind "Alt f" {
            Run "bash" "-c" "cd $PROJECT_DIR && source .venv/bin/activate 2>/dev/null; echo -e '\\033[1;96m── Novel Findings & Critiques ──\\033[0m'; echo; python3 dashboard/findings.py --novel --critiques 2>/dev/null || echo 'No database connection'; echo; echo -e '\\033[2mPress Enter to close\\033[0m'; read" {
                floating true
                close_on_exit true
            }
        }
        // Alt+c — stop running agents without quitting
        bind "Alt c" {
            Run "bash" "-c" "bash $PROJECT_DIR/dashboard/stop_agents.sh" {
                floating true
                close_on_exit true
            }
        }
        // Alt+s — start research task (interactive menu in floating pane)
        // Note: Alt+r is intercepted by terminal emulator, so we use Alt+s
        // Wrapper script kills existing run_research panes then exec's into a new one
        bind "Alt s" {
            Run "bash" "$PROJECT_DIR/dashboard/start_research.sh" {
                floating true
                close_on_exit true
            }
        }
        // Alt+w — close the currently focused pane
        bind "Alt w" { CloseFocus; }
        // Alt+x — toggle floating panes (hide/show without killing)
        bind "Alt x" { ToggleFloatingPanes; }
    }
}
